{
  "name": "plexaris-vibe-git-template",
  "repository": "stevepeak/plexaris-template",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Plexaris",
  "workspaces": {
    "packages": [
      "apps/*",
      "config/*",
      "packages/*"
    ],
    "catalog": {
      "@openrouter/ai-sdk-provider": "^2.1.1",
      "@opentelemetry/api": "^1.8.0",
      "@opentelemetry/sdk-node": "^0.212.0",
      "@sentry/nextjs": "^10.40.0",
      "@sentry/node": "^10.40.0",
      "@sentry/opentelemetry": "^10.40.0",
      "@tanstack/react-query": "^5.0.0",
      "@trigger.dev/react-hooks": "^4.4.1",
      "@trigger.dev/sdk": "^4.4.1",
      "@trigger.dev/build": "^4.4.1",
      "trigger.dev": "^4.4.1",
      "@trpc/client": "^11.10.0",
      "@trpc/react-query": "^11.10.0",
      "@trpc/server": "^11.10.0",
      "@types/node": "^25.3.2",
      "ai": "^6.0.105",
      "drizzle-orm": "^0.45.0",
      "eslint": "^9.37.0",
      "import-in-the-middle": "^3.0.0",
      "posthog-js": "^1.356.1",
      "posthog-node": "^5.26.0",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@app/web",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "prepare": "husky || true",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "ci": "bun run typecheck && bun run lint && bun run knip && bun run build",
    "fix": "turbo run fix",
    "clean": "turbo run clean | rm -rf .turbo",
    "kill": "&& lsof -i :3000 -t | xargs -r kill && lsof -i :3001 -t | xargs -r kill && lsof -i :3002 -t | xargs -r kill && lsof -i :6006 -t | xargs -r kill"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.2.0",
    "@ocavue/tsconfig": "^0.6.3",
    "eslint": "^9.37.0",
    "knip": "^5.85.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md,mdx}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.1.42",
  "engines": {
    "bun": "1"
  }
}
