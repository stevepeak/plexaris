# ===========================================
# Better Auth
# ===========================================
# Secret key for encryption/decryption. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-min-32-chars-long-here"
# Base URL for the auth service (your app's URL)
BETTER_AUTH_BASE_URL="http://localhost:3000"

# ===========================================
# Database
# ===========================================
# PostgreSQL connection string
DATABASE_URL="postgres://postgres@localhost:5432/kyoto"

# ===========================================
# Stripe
# ===========================================
# Publishable key (starts with pk_)
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Secret key (starts with sk_)
STRIPE_SECRET_KEY="sk_test_..."

# ===========================================
# AI
# ===========================================
# OpenRouter API key (starts with sk-or-v1-)
OPENROUTER_API_KEY="sk-or-v1-..."

# ===========================================
# Sentry
# ===========================================
# Sentry DSN for error tracking
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# Sentry auth token for source maps (starts with sntrys_), optional
SENTRY_AUTH_TOKEN="sntrys_..."

# ===========================================
# Resend
# ===========================================
# Resend API key for sending emails (starts with re_)
# https://resend.com/api-keys
RESEND_API_KEY="re_..."

# ===========================================
# Trigger.dev
# ===========================================
# Trigger.dev project reference (starts with proj_)
TRIGGER_PROJECT_REF="proj_..."
# Trigger.dev secret key (starts with tr_)
TRIGGER_SECRET_KEY="tr_..."

# ===========================================
# Cloudinary
# ===========================================
# Cloudinary connection URL for file uploads
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# ===========================================
# PostHog
# ===========================================
# PostHog API key for analytics, optional
POSTHOG_API_KEY=""
# PostHog ingestion host (defaults to https://us.i.posthog.com)
POSTHOG_HOST="https://us.i.posthog.com"
